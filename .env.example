# PostgreSQL (Docker Compose defaults shown)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smoke
POSTGRES_USER=smoke
POSTGRES_PASSWORD=smoke

# Kafka / Redpanda (host machine talking to published port)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# NASA FIRMS (required for live FIRMS ingestion — never commit real keys)
FIRMS_MAP_KEY=
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_BBOX=-125,24,-66,50
FIRMS_DAY_RANGE=1

# OpenAQ v3 (optional for many endpoints; set if you receive 401/403)
OPENAQ_API_KEY=

# Optional fixture-driven dry-run (no network; explicit test path)
FIRMS_DRY_RUN=0
FIRMS_FIXTURE_CSV=tests/fixtures/firms_sample.csv
OPENAQ_DRY_RUN=0
OPENAQ_FIXTURE_JSONL=tests/fixtures/openaq_sample.jsonl

# Smoke risk computation (used by scripts/run_compute_risk.sh inside Compose)
SMOKE_RISK_MODEL_VERSION=v2
SMOKE_RISK_LOOKBACK_HOURS=24
SMOKE_RISK_NEARBY_KM=50
SMOKE_RISK_GEOGRAPHIES=both

# Spark (inside Compose network)
SPARK_MASTER_URL=spark://spark-master:7077
JDBC_URL=jdbc:postgresql://postgres:5432/smoke
JDBC_USER=smoke
JDBC_PASSWORD=smoke

# Grafana (Compose profile `grafana`; host port avoids common :3000 conflicts)
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Census bootstrap overrides (default: Tennessee only via config/census.yaml)
# CENSUS_STATEFP=47
# CENSUS_STATEFPS=47,37,21
# CENSUS_LOAD_NATIONAL_COUNTIES=0

# Alert CLI thresholds (scripts/check_alerts.sh)
# ALERT_FRESHNESS_WARN_HOURS=6
# ALERT_FRESHNESS_CRITICAL_HOURS=24
# ALERT_HIGH_RISK_MIN_SCORE=75
# ALERT_LOOKBACK_HOURS=24
# ALERTS_WARN_ONLY=0

# Demo helper (scripts/demo_local.sh)
# DEMO_REFRESH_MVIEWS=1
