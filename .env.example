# PostgreSQL (Docker Compose defaults shown)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smoke
POSTGRES_USER=smoke
POSTGRES_PASSWORD=smoke

# Kafka / Redpanda (host machine talking to published port)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# NASA FIRMS (required for live FIRMS ingestion — never commit real keys)
FIRMS_MAP_KEY=
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_BBOX=-125,24,-66,50
FIRMS_DAY_RANGE=1

# OpenAQ v3 (optional for many endpoints; set if you receive 401/403)
OPENAQ_API_KEY=

# Optional fixture-driven dry-run (no network; explicit test path)
FIRMS_DRY_RUN=0
FIRMS_FIXTURE_CSV=tests/fixtures/firms_sample.csv
OPENAQ_DRY_RUN=0
OPENAQ_FIXTURE_JSONL=tests/fixtures/openaq_sample.jsonl

# Wind / NWS adapter (fixtures require no secrets; live uses WIND_STATION_IDS + User-Agent)
WIND_DRY_RUN=0
WIND_FIXTURE_JSONL=tests/fixtures/wind_sample.jsonl
WIND_SOURCE=nws
# WIND_BBOX=-125,24,-66,50
# WIND_STATION_IDS=KTYS,KCHA
# NWS_USER_AGENT=(your-app, contact@example.com)
WIND_MATCH_RADIUS_KM=100
WIND_MATCH_LOOKBACK_HOURS=6
PLUME_MAX_DISTANCE_KM=150
PLUME_HALF_ANGLE_DEGREES=30

# Smoke risk computation (used by scripts/run_compute_risk.sh inside Compose)
SMOKE_RISK_MODEL_VERSION=v2
SMOKE_RISK_LOOKBACK_HOURS=24
SMOKE_RISK_NEARBY_KM=50
SMOKE_RISK_GEOGRAPHIES=both

# Spark (inside Compose network)
SPARK_MASTER_URL=spark://spark-master:7077
JDBC_URL=jdbc:postgresql://postgres:5432/smoke
JDBC_USER=smoke
JDBC_PASSWORD=smoke

# Grafana (Compose profile `grafana`; host port avoids common :3000 conflicts)
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Census bootstrap overrides (default: Tennessee only via config/census.yaml)
# CENSUS_STATEFP=47
# CENSUS_STATEFPS=47,37,21
# CENSUS_LOAD_NATIONAL_COUNTIES=0

# Alert CLI thresholds (scripts/check_alerts.sh)
# ALERT_FRESHNESS_WARN_HOURS=6
# ALERT_FRESHNESS_CRITICAL_HOURS=24
# ALERT_HIGH_RISK_MIN_SCORE=75
# ALERT_HIGH_PLUME_EXPOSURE_MIN_SCORE=70
# ALERT_LOOKBACK_HOURS=24
# ALERT_PARSE_ERRORS_WARN_COUNT=1
# ALERT_PARSE_ERRORS_CRITICAL_COUNT=25
# ALERT_CONSUMER_OFFSET_STALE_HOURS=6
# ALERTS_WARN_ONLY=0

# Phase 7 — DLQ replay + extended smoke (scripts/replay_dlq.sh, scripts/smoke_test.sh)
# DRY_RUN=1
# DLQ_SOURCE_MODE=postgres
# DLQ_TOPIC=
# SOURCE_TOPIC=
# TARGET_DATASET=
# STATUS=open
# DLQ_REPLAY_LIMIT=50
# DLQ_RESOLVE_ON_REPLAY=0
# DLQ_SMOKE=0

# Phase 4 — materialized incidents + notifications
# ALERTS_DRY_RUN=0
# ALERTS_RESOLVE_MISSING=0
# ALERT_NOTIFIER=console
# ALERT_SEVERITY_MIN=high
# ALERT_LIMIT=20
# FORCE_NOTIFY=0
# ALERT_WEBHOOK_URL=
# ALERT_WEBHOOK_HEADERS_JSON=
# SLACK_WEBHOOK_URL=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_EMAIL_FROM=
# ALERT_EMAIL_TO=

# Bounded live ingest (scripts/live_ingest_once.sh)
# LIVE_INGEST_BBOX=-88.2,34.9,-81.6,36.7
# LIVE_INGEST_MAX_SPAN_DEG=14
# LIVE_INGEST_ALLOW_LARGE_BBOX=0

# Operational cycle (scripts/run_operational_cycle.sh)
# LIVE_MODE=0

# Phase 5 — digest + retry tuning
# ALERT_DIGEST=0
# ALERT_DIGEST_WINDOW_HOURS=24
# ALERT_DIGEST_MAX_ITEMS=50
# ALERT_MAX_ATTEMPTS=5
# ALERT_RETRY_DISABLED=0
# ALERT_RETRY_QUEUE=0
# ALERT_SEND_COOLDOWN_SECONDS=0

# Phase 5 — optional Compose scheduler profile (docker-compose.yml --profile scheduler)
# OPERATIONAL_INTERVAL_SECONDS=3600

# Demo helper (scripts/demo_local.sh)
# DEMO_REFRESH_MVIEWS=1
