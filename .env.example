# PostgreSQL (Docker Compose defaults shown)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smoke
POSTGRES_USER=smoke
POSTGRES_PASSWORD=smoke

# Kafka / Redpanda (host machine talking to published port)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# NASA FIRMS (required for live FIRMS ingestion — never commit real keys)
FIRMS_MAP_KEY=
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_BBOX=-125,24,-66,50
FIRMS_DAY_RANGE=1

# OpenAQ v3 (optional for many endpoints; set if you receive 401/403)
OPENAQ_API_KEY=

# Optional fixture-driven dry-run (no network; explicit test path)
FIRMS_DRY_RUN=0
FIRMS_FIXTURE_CSV=tests/fixtures/firms_sample.csv
OPENAQ_DRY_RUN=0
OPENAQ_FIXTURE_JSONL=tests/fixtures/openaq_sample.jsonl

# Spark (inside Compose network)
SPARK_MASTER_URL=spark://spark-master:7077
JDBC_URL=jdbc:postgresql://postgres:5432/smoke
JDBC_USER=smoke
JDBC_PASSWORD=smoke
