# PostgreSQL (Docker Compose defaults shown)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smoke
POSTGRES_USER=smoke
POSTGRES_PASSWORD=smoke

# Kafka / Redpanda (host machine talking to published port)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# NASA FIRMS (required for live FIRMS ingestion — never commit real keys)
FIRMS_MAP_KEY=
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_BBOX=-125,24,-66,50
FIRMS_DAY_RANGE=1

# OpenAQ v3 (optional for many endpoints; set if you receive 401/403)
OPENAQ_API_KEY=

# Optional fixture-driven dry-run (no network; explicit test path)
FIRMS_DRY_RUN=0
FIRMS_FIXTURE_CSV=tests/fixtures/firms_sample.csv
OPENAQ_DRY_RUN=0
OPENAQ_FIXTURE_JSONL=tests/fixtures/openaq_sample.jsonl

# Wind / NWS adapter (fixtures require no secrets; live uses WIND_STATION_IDS + User-Agent)
WIND_DRY_RUN=0
WIND_FIXTURE_JSONL=tests/fixtures/wind_sample.jsonl
WIND_SOURCE=nws
# WIND_BBOX=-88.2,34.9,-81.6,36.7
# WIND_STATION_IDS=KTYS,KCHA
# WIND_STATION_DISCOVERY_LIMIT=25
# WIND_STATION_DISCOVERY_RADIUS_KM=
# NWS_STATIONS_FIXTURE_JSON=tests/fixtures/nws_stations_sample.json
# NWS_USER_AGENT=(your-app, contact@example.com)
WIND_MATCH_RADIUS_KM=100
WIND_MATCH_LOOKBACK_HOURS=6
PLUME_MAX_DISTANCE_KM=150
PLUME_HALF_ANGLE_DEGREES=30

# Smoke risk computation (used by scripts/run_compute_risk.sh inside Compose)
SMOKE_RISK_MODEL_VERSION=v2
SMOKE_RISK_LOOKBACK_HOURS=24
SMOKE_RISK_NEARBY_KM=50
SMOKE_RISK_GEOGRAPHIES=both

# Spark (inside Compose network)
SPARK_MASTER_URL=spark://spark-master:7077
JDBC_URL=jdbc:postgresql://postgres:5432/smoke
JDBC_USER=smoke
JDBC_PASSWORD=smoke

# Grafana (Compose profile `grafana`; host port avoids common :3000 conflicts)
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Census bootstrap overrides (default: Tennessee only via config/census.yaml)
# CENSUS_STATEFP=47
# CENSUS_STATEFPS=47,37,21
# CENSUS_LOAD_NATIONAL_COUNTIES=0

# Alert CLI thresholds (scripts/check_alerts.sh)
# ALERT_FRESHNESS_WARN_HOURS=6
# ALERT_FRESHNESS_CRITICAL_HOURS=24
# ALERT_HIGH_RISK_MIN_SCORE=75
# ALERT_HIGH_PLUME_EXPOSURE_MIN_SCORE=70
# ALERT_LOOKBACK_HOURS=24
# ALERT_PARSE_ERRORS_WARN_COUNT=1
# ALERT_PARSE_ERRORS_CRITICAL_COUNT=25
# ALERT_CONSUMER_OFFSET_STALE_HOURS=6
# ALERT_PARSER_SPIKE_WARN_COUNT=15
# ALERT_PARSER_SPIKE_CRITICAL_COUNT=40
# ALERT_KAFKA_LAG_WARN_MESSAGES=100
# ALERT_KAFKA_LAG_CRITICAL_MESSAGES=1000
# ALERT_DLQ_DEPTH_WARN_MESSAGES=1
# ALERT_DLQ_DEPTH_CRITICAL_MESSAGES=100
# ALERTS_WARN_ONLY=0

# Phase 9 — bounded gridded weather + fire matching + plume wind_grid_v2 + risk v4
# GRID_WEATHER_ENABLED=0
# GRID_WEATHER_SOURCE=nws_gridpoint
# GRID_WEATHER_DRY_RUN=1
# GRID_WEATHER_FIXTURE_JSON=tests/fixtures/nws_gridpoint_sample.json
# GRID_WEATHER_BBOX=min_lon,min_lat,max_lon,max_lat
# GRID_WEATHER_MAX_POINTS=100
# GRID_WEATHER_LOOKAHEAD_HOURS=24
# GRID_WEATHER_VARIABLES=windSpeed,windDirection,temperature,relativeHumidity
# GRID_WEATHER_CELL_SIZE_DEGREES=0.05
# GRID_WEATHER_REFUSE_LARGE_BBOX=1
# GRID_WEATHER_REPLAY_WITH_FIXTURES=0
# FIRE_WEATHER_MATCH_RADIUS_KM=50
# FIRE_WEATHER_MATCH_MAX_TIME_DELTA_HOURS=3
# FIRE_WEATHER_MATCH_METHOD=nearest_grid_cell
# PLUME_MODEL_VERSION=wind_v1
# PLUME_GRID_FALLBACK_TO_STATION=1
# RISK_MODEL_VERSION=v2
# ALERT_GRID_WEATHER_STALE_HOURS=6
# ALERT_FIRE_WEATHER_UNMATCHED_WARN_COUNT=5
# ALERT_FIRE_WEATHER_UNMATCHED_CRITICAL_COUNT=25
# GRID_WEATHER_SMOKE=0

# Phase 10 — fixture time alignment, aligned samples, integration assertions, NWS points, calibration hooks
# FIXTURE_TIME_MODE=static
# FIXTURE_RELATIVE_BASE_HOURS_AGO=1
# USE_ALIGNED_FIXTURES=0
# STRICT_ALIGNED_ASSERTS=0
# EXPECT_PARSE_ERRORS=0
# SKIP_BOOTSTRAP=1
# RUN_BOOTSTRAP=0
# GRID_WEATHER_POINTS=-86.78,36.16
# GRID_WEATHER_MAX_POINTS=50
# RISK_EVAL_OBSERVATION_TYPE=risk_score
# EXPECT_DISPERSION=0

# Phase 11 — Gaussian dispersion proxy (not HYSPLIT; disabled by default)
# DISPERSION_ENABLED=0
# DISPERSION_MODEL_VERSION=gaussian_v0
# DISPERSION_MAX_DISTANCE_KM=150
# DISPERSION_CROSSWIND_SIGMA_KM=15
# DISPERSION_DOWNWIND_SIGMA_KM=75
# DISPERSION_MIN_WIND_SPEED_MPS=0.5
# DISPERSION_SOURCE_STRENGTH_MODE=frp
# DISPERSION_GRID_RESOLUTION_KM=10
# DISPERSION_MAX_TARGET_GEOGRAPHIES=500
# DISPERSION_LOOKBACK_HOURS=24
# DISPERSION_USE_GRID_WEATHER=1
# DISPERSION_FALLBACK_TO_STATION_WIND=1
# DISPERSION_WRITE_DEBUG_FIELDS=1
# DISPERSION_ALLOW_LARGE_RUN=0
# ALERT_HIGH_DISPERSION_EXPOSURE_MIN_SCORE=70
# ALERT_DISPERSION_NO_WIND_MATCHES_HOURS=24
# ALERT_DISPERSION_AQ_MISMATCH_MIN_SCORE=50
# DISPERSION_SMOKE=0

# Phase 12 — calibration / evaluation (not validation)
# CALIBRATION_MIN_AQ_OBSERVATIONS=3
# CALIBRATION_HIGH_PM25_THRESHOLD=35
# CALIBRATION_LOW_PM25_THRESHOLD=12
# CALIBRATION_HIGH_DISPERSION_SCORE=70
# CALIBRATION_LOW_DISPERSION_SCORE=25
# CALIBRATION_LAG_WINDOWS_HOURS=0-3,3-6,6-12,12-24
# RISK_EVAL_MIN_MATCH_COUNT=3
# RISK_EVAL_HIGH_RISK_THRESHOLD=70
# RISK_EVAL_HIGH_OBS_THRESHOLD=35
# RISK_EVAL_MODEL_VERSION=v5
# STRICT_EVALUATION=0
# STRICT_CALIBRATION_ASSERTS=0
# LOAD_RISK_OBSERVATION_FIXTURES=0
# RISK_OBSERVATION_FIXTURE_JSONL=tests/fixtures/risk_observations_sample.jsonl
# ALERT_MODEL_MISMATCH_MIN_COUNT=3
# ALERT_AQ_OBSERVATION_COVERAGE_MIN_COUNT=3
# ALERT_CALIBRATION_WARN_ONLY=1
# CALIBRATION_SMOKE=0

# Phase 8 — broker lag collection + parse-error compaction + quality strictness
# COLLECT_LAG=1
# STRICT_LAG_COLLECTION=0
# STRICT_QUALITY=0
# PARSE_ERROR_COMPACT_OLDER_THAN_DAYS=30
# PARSE_ERROR_COMPACT_STATUS=resolved

# Phase 7 — DLQ replay + extended smoke (scripts/replay_dlq.sh, scripts/smoke_test.sh)
# DRY_RUN=1
# DLQ_SOURCE_MODE=postgres
# DLQ_TOPIC=
# SOURCE_TOPIC=
# TARGET_DATASET=
# STATUS=open
# DLQ_REPLAY_LIMIT=50
# DLQ_RESOLVE_ON_REPLAY=0
# DLQ_REPLAY_BOOKKEEPING=1
# DLQ_SMOKE=0

# Phase 4 — materialized incidents + notifications
# ALERTS_DRY_RUN=0
# ALERTS_RESOLVE_MISSING=0
# ALERT_NOTIFIER=console
# ALERT_SEVERITY_MIN=high
# ALERT_LIMIT=20
# FORCE_NOTIFY=0
# ALERT_WEBHOOK_URL=
# ALERT_WEBHOOK_HEADERS_JSON=
# SLACK_WEBHOOK_URL=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_EMAIL_FROM=
# ALERT_EMAIL_TO=

# Bounded live ingest (scripts/live_ingest_once.sh)
# LIVE_INGEST_BBOX=-88.2,34.9,-81.6,36.7
# LIVE_INGEST_MAX_SPAN_DEG=14
# LIVE_INGEST_ALLOW_LARGE_BBOX=0

# Operational cycle (scripts/run_operational_cycle.sh)
# LIVE_MODE=0

# Phase 5 — digest + retry tuning
# ALERT_DIGEST=0
# ALERT_DIGEST_WINDOW_HOURS=24
# ALERT_DIGEST_MAX_ITEMS=50
# ALERT_MAX_ATTEMPTS=5
# ALERT_RETRY_DISABLED=0
# ALERT_RETRY_QUEUE=0
# ALERT_SEND_COOLDOWN_SECONDS=0

# Phase 5 — optional Compose scheduler profile (docker-compose.yml --profile scheduler)
# OPERATIONAL_INTERVAL_SECONDS=3600

# Demo helper (scripts/demo_local.sh)
# DEMO_REFRESH_MVIEWS=1

# Phase 13 — CI / exports / minimal census (see README + docs/release/v0.1.0.md)
# CALIBRATION_EXPORT_DIR=artifacts/calibration
# CALIBRATION_EXPORT_FORMATS=csv
# CALIBRATION_EXPORT_INCLUDE_PARQUET=0
# CALIBRATION_EXPORT_DRY_RUN=0
# COMPOSE_INTEGRATION=0
# MINIMAL_CENSUS_REPLACE_ALL=0
# MINIMAL_CENSUS_COUNTIES_GEOJSON=tests/fixtures/census_minimal_counties.geojson
# MINIMAL_CENSUS_TRACTS_GEOJSON=tests/fixtures/census_minimal_tracts.geojson

# Phase 14 — DB drift checks / isolated release tests / manifest (see README + docs/release/v1.0.0-checklist.md)
# DB_DOCTOR_WARN_ONLY=0
# FULL_CENSUS=0
# KEEP_RELEASE_STACK=0
# FULL_RELEASE_TEST=0
# RELEASE_MANIFEST_DRY_RUN=0
# RELEASE_COMPOSE_PROJECT_NAME=wildfire-smoke-release-test
